{
  "theme": "cinema",
  "frame": { "align": "top", "padding": "compact" },
  "backdrop": { "variant": "grid" },
  "content": { "width": "wide", "density": "comfortable", "align": "left" },
  "header": {
    "meta": "Акт I · Обычный мир",
    "title": "Раньше"
  },
  "layout": {
    "type": "splitLayout",
    "gap": "md",
    "leftSpan": 6,
    "rightSpan": 6,
    "left": {
      "kind": "card",
      "card": {
        "tone": "standard",
        "leadingIcon": "rocket",
        "justify": "between",
        "subtitle": { "variant": "overline", "text": "Как запускали MVP" },
        "items": [
          { "variant": "h2", "text": "Продукт — это команда из шести человек и полгода" },
          { "variant": "body", "text": "Критический путь упирался в найм и бюджет, а не в идею. Продуктовая разработка была доступна тем, у кого есть команда." }
        ]
      }
    },
    "right": {
      "kind": "layout",
      "layout": {
        "type": "stackLayout",
        "gap": "md",
        "items": [
          {
            "span": 6,
            "region": {
              "kind": "layout",
              "layout": {
                "type": "equalColumns",
                "gap": "md",
                "items": [
                  {
                    "span": 6,
                    "region": {
                      "kind": "card",
                      "card": {
                        "tone": "standard",
                        "leadingIcon": "clock",
                        "justify": "between",
                        "subtitle": { "variant": "overline", "text": "Время" },
                        "items": [
                          { "variant": "h2", "text": "6 месяцев" },
                          { "variant": "body", "text": "от идеи до первой версии" }
                        ]
                      }
                    }
                  },
                  {
                    "span": 6,
                    "region": {
                      "kind": "card",
                      "card": {
                        "tone": "standard",
                        "leadingIcon": "circle-dollar-sign",
                        "justify": "between",
                        "subtitle": { "variant": "overline", "text": "Бюджет" },
                        "items": [
                          { "variant": "h2", "text": "$50–200K" },
                          { "variant": "body", "text": "зарплаты и подрядчики до MVP" }
                        ]
                      }
                    }
                  }
                ]
              }
            }
          },
          {
            "span": 6,
            "region": {
              "kind": "card",
              "card": {
                "tone": "standard",
                "leadingIcon": "users",
                "justify": "between",
                "subtitle": { "variant": "overline", "text": "Команда" },
                "items": [
                  { "variant": "h2", "text": "5–6 ролей" },
                  { "variant": "body", "text": "фронт, бэк, дизайн, devops, PM, QA" }
                ]
              }
            }
          }
        ]
      }
    }
  }
}
