                    "tone": "standard",
                    "padding": "compact",
                    "stackGap": "xs",
                    "leadingIcon": "layout-template",
                    "justify": "between",
                    "slots": [
                      {
                        "items": [
                          { "variant": "h3", "text": "Проектные правила" }
                        ]
                      },
                      {
                        "items": [
                          {
                            "variant": "body",
                            "text": "Хранятся в `.cursor/rules`, под версионным контролем вместе с репозиторием и относятся только к этому коду."
                          }
                        ]
                      }
                    ]
                  }
                }
              },
              {
                "span": 6,
                "region": {
                  "kind": "card",
                  "card": {
                    "tone": "standard",
                    "padding": "compact",
                    "stackGap": "xs",
                    "leadingIcon": "type",
                    "justify": "between",
                    "slots": [
                      {
                        "items": [
                          { "variant": "h3", "text": "AGENTS.md" }
