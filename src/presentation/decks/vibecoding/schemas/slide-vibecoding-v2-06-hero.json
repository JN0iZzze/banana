{
  "template": "textStack",
  "frame": { "align": "center", "padding": "default" },
  "backdrop": { "variant": "spotlight", "borderFrame": true },
  "content": { "width": "wide", "align": "center", "density": "comfortable" },
  "stack": {
    "align": "center",
    "justify": "center",
    "gap": "md",
    "reveal": { "preset": "soft", "baseDelay": 0, "step": 0.1 },
    "items": [
      { "type": "text", "variant": "overline", "text": "Вайбкодинг" },
      {
        "type": "text",
        "variant": "h1",
        "size": "section",
        "chunks": [
          { "text": "Путь", "decoration": "lineThrough" },
          { "text": " вайб героя" }
        ]
      },
      { "type": "image", "src": "/vibe/hero.png", "alt": "Вайб героя", "width": 440 },
      { "type": "text", "variant": "lead", "text": "Один в\u00A0кадре: идея, вкус и\u00A0путь до\u00A0запуска." }
    ]
  }
}
