{
  "frame": { "align": "top", "padding": "compact" },
  "backdrop": { "variant": "grid" },
  "content": { "width": "wide", "density": "compact", "align": "left" },
  "header": {
    "meta": "Акт II · Что такое агент",
    "title": "Чат vs Агент"
  },
  "layout": {
    "type": "splitLayout",
    "gap": "md",
    "leftSpan": 6,
    "rightSpan": 6,
    "left": {
      "kind": "card",
      "card": {
        "tone": "standard",
        "padding": "default",
        "leadingIcon": "bot",
        "justify": "between",
        "slots": [
          {
            "items": [
              { "variant": "overline", "text": "В чём разница" },
              {
                "variant": "h2",
                "text": "ChatGPT работает только с текстом запроса. Агент — с файлами и командами"
              }
            ]
          },
          {
            "gap": "xs",
            "items": [
              {
                "variant": "body",
                "text": "В чате контекст ограничен тем, что ты передал в сообщении и истории диалога."
              },
              {
                "variant": "body",
                "text": "Агент опирается на состояние проекта: читает файлы, запускает команды и видит результат."
              }
            ]
          }
        ]
      }
    },
    "right": {
      "kind": "layout",
      "layout": {
        "type": "mediaGallery",
        "preset": "single",
        "gap": "md",
        "cellVariant": "fill",
        "items": [
          {
            "type": "video",
            "src": "/vibe/agent.mp4",
            "autoplay": true,
            "loop": true,
            "muted": true,
            "playsInline": true,
            "objectFit": "cover"
          }
        ]
      }
    }
  }
}
